{
  "schema_version": "v1",
  "dataset": "udemy_user_course_activity_curated",
  "partition_keys": ["event_year", "event_month", "event_day"],
  "fields": [
    {"name": "learner_email_sha256", "type": "string"},
    {"name": "learner_given_name", "type": "string"},
    {"name": "learner_surname", "type": "string"},
    {"name": "learner_role", "type": "string"},
    {"name": "course_id", "type": "int64", "nullable": true},
    {"name": "course_title", "type": "string"},
    {"name": "course_category", "type": "string"},
    {"name": "course_primary_category", "type": "string"},
    {"name": "course_category_count", "type": "int64", "nullable": true},
    {"name": "course_duration_minutes", "type": "float64"},
    {"name": "video_consumed_minutes", "type": "float64"},
    {"name": "completion_ratio_pct", "type": "float64"},
    {"name": "is_assigned", "type": "boolean", "nullable": true},
    {"name": "enrolled_at", "type": "timestamp_utc"},
    {"name": "started_at", "type": "timestamp_utc"},
    {"name": "completed_at", "type": "timestamp_utc"},
    {"name": "first_completed_at", "type": "timestamp_utc"},
    {"name": "source_ingested_at", "type": "timestamp_utc"},
    {"name": "last_activity_date", "type": "date"},
    {"name": "source_environment", "type": "string"},
    {"name": "event_year", "type": "string"},
    {"name": "event_month", "type": "string"},
    {"name": "event_day", "type": "string"},
    {"name": "record_loaded_at", "type": "timestamp_utc"}
  ]
}
